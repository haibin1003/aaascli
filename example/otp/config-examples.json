{
  "_comment": "OTP 配置示例 - 可复制到 ~/.lc/config.json 中使用",
  "examples": {
    "minimal": {
      "comment": "最小配置 - 只启用 OTP，使用默认保护列表",
      "cookie": "your-cookie-here",
      "readonly": true,
      "otp": {
        "enabled": true,
        "secret": "YOUR_BASE32_SECRET_HERE",
        "sessionExpiryMinutes": 5
      }
    },
    "strict": {
      "comment": "严格配置 - 保护所有写操作",
      "cookie": "your-cookie-here",
      "readonly": true,
      "otp": {
        "enabled": true,
        "secret": "YOUR_BASE32_SECRET_HERE",
        "sessionExpiryMinutes": 10,
        "protectedCommands": [
          "repo delete",
          "readonly off",
          "pr merge",
          "pr create",
          "req delete",
          "task delete",
          "bug delete"
        ]
      }
    },
    "custom": {
      "comment": "自定义配置 - 只保护仓库删除",
      "cookie": "your-cookie-here",
      "readonly": true,
      "otp": {
        "enabled": true,
        "secret": "YOUR_BASE32_SECRET_HERE",
        "sessionExpiryMinutes": 30,
        "protectedCommands": [
          "repo delete"
        ]
      }
    },
    "ci": {
      "comment": "CI/CD 配置 - 较长会话有效期",
      "cookie": "your-cookie-here",
      "readonly": false,
      "otp": {
        "enabled": true,
        "secret": "YOUR_BASE32_SECRET_HERE",
        "sessionExpiryMinutes": 60,
        "protectedCommands": [
          "repo delete",
          "readonly off"
        ]
      }
    }
  },
  "field_descriptions": {
    "otp.enabled": "是否启用 OTP 二次验证",
    "otp.secret": "TOTP 密钥 (Base32 编码，20字节)",
    "otp.verifiedAt": "最后验证时间 (ISO8601 格式，系统自动维护)",
    "otp.sessionExpiryMinutes": "验证会话有效期，默认 5 分钟",
    "otp.protectedCommands": "需要 OTP 验证的命令列表，空数组或未设置时使用默认列表"
  },
  "default_protected_commands": [
    "repo delete",
    "readonly off"
  ],
  "available_commands": [
    "pr merge",
    "pr create",
    "pr review",
    "req delete",
    "task delete",
    "bug delete",
    "repo delete",
    "readonly off"
  ]
}
